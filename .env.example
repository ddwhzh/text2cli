# ── LLM Provider ──────────────────────────────────
# Provider: "openai" (default, OpenAI-compatible) or "zhipuai"
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_MODEL=glm-4-flash
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_TEMPERATURE=0.7

# Legacy aliases (still supported):
# GLM_API_KEY=...
# ZHIPUAI_API_KEY=...

# ── Langfuse Observability ────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ── Brave Search ───────────────────────────────────
BRAVE_API_KEY=your-brave-api-key-here

# ── Cache ──────────────────────────────────────────
# T2_REDIS_URL=redis://localhost:6379/0
# Falls back to in-process LRU if Redis not available

# ── Code Executor (FUSE) ──────────────────────────
# FUSE mount base (auto-detected; override for custom path)
# T2_FUSE_MOUNT_BASE=/tmp/t2-fuse
# Code execution timeout (seconds, max 120)
# T2_EXEC_TIMEOUT=30

# ── Server ─────────────────────────────────────────
T2_HOST=127.0.0.1
T2_PORT=8770
T2_DB=.text2cli/workspace.db
