# ── LLM Provider ──────────────────────────────────
# Provider: "openai" (default, OpenAI-compatible) or "zhipuai"
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_MODEL=glm-4-flash
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_TEMPERATURE=0.7

# Legacy aliases (still supported):
# GLM_API_KEY=...
# ZHIPUAI_API_KEY=...

# ── Langfuse Observability ────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ── Brave Search ───────────────────────────────────
BRAVE_API_KEY=your-brave-api-key-here

# ── Cache ──────────────────────────────────────────
# T2_REDIS_URL=redis://localhost:6379/0
# Falls back to in-process LRU if Redis not available

# ── Code Executor (FUSE) ──────────────────────────
# FUSE mount base (auto-detected; override for custom path)
# T2_FUSE_MOUNT_BASE=/tmp/t2-fuse
# Code execution mode:
# - local-trusted   (default): host subprocess with minimal hardening
# - local-untrusted: untrusted code mode (DEFAULT disables host backend; use docker backend on Linux)
# T2_EXEC_MODE=local-trusted
# Code execution backend:
# - host   (default)
# - docker (Linux-first; bind-mounts the FUSE mount into a container)
# - microvm (Linux-first; VM-backed runtime via Docker alternative runtime/shim)
#   - example runtimeType: io.containerd.kata.v2 (must be installed on Docker daemon host)
# - remote (remote sandbox service; can be docker-backed or microVM-backed depending on server runtime)
# T2_EXEC_BACKEND=host
# MicroVM backend settings:
# T2_EXEC_MICROVM_RUNTIME=io.containerd.kata.v2
# Docker backend settings:
# T2_EXEC_DOCKER_IMAGE=python:3.12-slim
# T2_EXEC_DOCKER_NETWORK=none
# Remote sandbox backend settings:
# - Run `t2-sandbox` on a Linux host, then point the web app at it.
# T2_EXEC_REMOTE_URL=http://127.0.0.1:9770
# T2_EXEC_REMOTE_TOKEN=
# Scheduler (filter+score+bind):
# T2_EXEC_SCHEDULER=0
# T2_EXEC_POOL_WEIGHTS=security=5,latency=4,cost=2,hit_rate=0
# (Optional) scheduler hints:
# T2_EXEC_POOL_HIT_RATES=host=99,docker=98,microvm=97,remote=96
# T2_EXEC_REQUIRED_RESIDENCY=local   # or remote
# T2_EXEC_REQUIRED_PERMISSION_DOMAIN=container  # host/container/microvm/remote
# Remote snapshot caps (sent to remote sandbox):
# T2_EXEC_REMOTE_MAX_FILES=2000
# T2_EXEC_REMOTE_MAX_BYTES=5000000
# Code execution timeout (seconds, max 120)
# T2_EXEC_TIMEOUT=30
# Max stdout/stderr chars captured per execution (hard cap)
# T2_EXEC_MAX_OUTPUT_CHARS=50000
# Extra env vars to remove from child process (comma-separated)
# T2_EXEC_ENV_DENYLIST=
# Extra env vars to allow through in local-untrusted mode (comma-separated)
# T2_EXEC_ENV_ALLOWLIST=
# Resource limits (best-effort; platform-dependent)
# T2_EXEC_MAX_PROCS=64
# T2_EXEC_MAX_NOFILE=256
# T2_EXEC_MAX_FSIZE_BYTES=10485760

# ── Remote Sandbox Service (t2-sandbox) ────────────
# T2_SANDBOX_HOST=127.0.0.1
# T2_SANDBOX_PORT=9770
# T2_SANDBOX_TOKEN=
# T2_SANDBOX_MAX_BODY_BYTES=5000000
# (Optional) use microVM-backed docker runtime on the server:
# T2_SANDBOX_DOCKER_RUNTIME=io.containerd.kata.v2

# ── Server ─────────────────────────────────────────
T2_HOST=127.0.0.1
T2_PORT=8770
T2_DB=.text2cli/workspace.db
